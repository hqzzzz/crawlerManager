{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Crawler Server",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "--inspect-brk",
        "src/server/index.ts"
      ],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "restart": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Crawler",
      "cwd": "${workspaceFolder}/crawlerXnode/",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "node",
        "crawler/madouqu-crawler.js"
      ],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal"
    },
  ]
}